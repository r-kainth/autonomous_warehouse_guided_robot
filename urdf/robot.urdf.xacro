<?xml version="1.0"?>
<robot name="forklift">

  <material name="orange"><color rgba="1 0.5 0 1"/></material>
  <material name="black"><color rgba="0.1 0.1 0.1 1"/></material>
  <material name="yellow"><color rgba="1 1 0 1"/></material>

  <!-- BASE -->
  <link name="base_footprint"/>
  
  <link name="base_link">
    <visual>
      <geometry><box size="0.6 0.5 0.15"/></geometry>
      <material name="orange"/>
    </visual>
    <collision>
      <geometry><box size="0.6 0.5 0.15"/></geometry>
    </collision>
    <inertial>
      <mass value="8.0"/>
      <inertia ixx="0.2" ixy="0" ixz="0" iyy="0.3" iyz="0" izz="0.2"/>
    </inertial>
  </link>
  
  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.125"/>
  </joint>

  <!-- MAST -->
  <link name="mast_link">
    <visual>
      <geometry><box size="0.05 0.3 1.0"/></geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry><box size="0.05 0.3 1.0"/></geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.04" ixy="0" ixz="0" iyy="0.04" iyz="0" izz="0.001"/>
    </inertial>
  </link>
  
  <joint name="mast_joint" type="fixed">
    <parent link="base_link"/>
    <child link="mast_link"/>
    <origin xyz="0.35 0 0.4"/>
  </joint>

  <!-- FORK CARRIAGE (moves up/down) -->
  <link name="fork_carriage">
    <visual>
      <geometry><box size="0.05 0.3 0.05"/></geometry>
      <material name="yellow"/>
    </visual>
    <collision>
      <geometry><box size="0.05 0.3 0.05"/></geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.005" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.005"/>
    </inertial>
  </link>
  
  <joint name="fork_lift_joint" type="prismatic">
    <parent link="mast_link"/>
    <child link="fork_carriage"/>
    <origin xyz="0.05 0 -0.48"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.12" upper="0.5" effort="50000" velocity="5.0"/>
    <dynamics damping="50.0" friction="0.0"/>
  </joint>

  <gazebo reference="fork_lift_joint">
    <implicitSpringDamper>false</implicitSpringDamper>
    <provideFeedback>true</provideFeedback>
  </gazebo>

  <!-- LEFT FORK TINE (Extended to 0.65m) -->
  <link name="left_fork">
    <visual>
      <origin xyz="0.325 0 0"/>
      <geometry><box size="0.65 0.08 0.02"/></geometry>
      <material name="yellow"/>
    </visual>
    <collision>
      <origin xyz="0.325 0 0"/>
      <geometry><box size="0.65 0.08 0.02"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0.325 0 0"/>
      <mass value="0.01"/>
      <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>
  
  <joint name="left_fork_joint" type="fixed">
    <parent link="fork_carriage"/>
    <child link="left_fork"/>
    <origin xyz="0.05 0.11 0"/>
  </joint>

  <!-- RIGHT FORK TINE (Extended to 0.65m) -->
  <link name="right_fork">
    <visual>
      <origin xyz="0.325 0 0"/>
      <geometry><box size="0.65 0.08 0.02"/></geometry>
      <material name="yellow"/>
    </visual>
    <collision>
      <origin xyz="0.325 0 0"/>
      <geometry><box size="0.65 0.08 0.02"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0.325 0 0"/>
      <mass value="0.01"/>
      <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>
  
  <joint name="right_fork_joint" type="fixed">
    <parent link="fork_carriage"/>
    <child link="right_fork"/>
    <origin xyz="0.05 -0.11 0"/>
  </joint>

  <!-- CAMERA -->
  <link name="camera_link">
    <visual>
      <geometry><box size="0.02 0.06 0.02"/></geometry>
      <material name="black"/>
    </visual>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>
  
  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="0.3 0 0.08"/>
  </joint>

  <!-- LEFT FRONT WHEEL -->
  <link name="left_front_wheel">
    <visual>
      <origin rpy="1.57 0 0"/>
      <geometry><cylinder radius="0.1" length="0.06"/></geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin rpy="1.57 0 0"/>
      <geometry><cylinder radius="0.1" length="0.06"/></geometry>
    </collision>
    <inertial>
      <mass value="2.0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.015" iyz="0" izz="0.01"/>
    </inertial>
  </link>
  <joint name="left_front_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_front_wheel"/>
    <origin xyz="0.2 0.25 -0.1"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>

  <!-- LEFT REAR WHEEL -->
  <link name="left_rear_wheel">
    <visual>
      <origin rpy="1.57 0 0"/>
      <geometry><cylinder radius="0.1" length="0.06"/></geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin rpy="1.57 0 0"/>
      <geometry><cylinder radius="0.1" length="0.06"/></geometry>
    </collision>
    <inertial>
      <mass value="2.0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.015" iyz="0" izz="0.01"/>
    </inertial>
  </link>
  <joint name="left_rear_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_rear_wheel"/>
    <origin xyz="-0.2 0.25 -0.1"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.0" friction="0.0"/>
  </joint>

  <!-- RIGHT FRONT WHEEL -->
  <link name="right_front_wheel">
    <visual>
      <origin rpy="1.57 0 0"/>
      <geometry><cylinder radius="0.1" length="0.06"/></geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin rpy="1.57 0 0"/>
      <geometry><cylinder radius="0.1" length="0.06"/></geometry>
    </collision>
    <inertial>
      <mass value="2.0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.015" iyz="0" izz="0.01"/>
    </inertial>
  </link>
  <joint name="right_front_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_front_wheel"/>
    <origin xyz="0.2 -0.25 -0.1"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>

  <!-- RIGHT REAR WHEEL -->
  <link name="right_rear_wheel">
    <visual>
      <origin rpy="1.57 0 0"/>
      <geometry><cylinder radius="0.1" length="0.06"/></geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin rpy="1.57 0 0"/>
      <geometry><cylinder radius="0.1" length="0.06"/></geometry>
    </collision>
    <inertial>
      <mass value="2.0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.015" iyz="0" izz="0.01"/>
    </inertial>
  </link>
  <joint name="right_rear_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_rear_wheel"/>
    <origin xyz="-0.2 -0.25 -0.1"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.0" friction="0.0"/>
  </joint>

  <!-- ros2_control for joint control -->
  <ros2_control name="GazeboSystem" type="system">
    <hardware>
      <plugin>gazebo_ros2_control/GazeboSystem</plugin>
    </hardware>
    
    <!-- Drive wheels (front wheels only for better turning like real forklifts) -->
    <joint name="left_front_wheel_joint">
      <command_interface name="velocity">
        <param name="min">-10</param>
        <param name="max">10</param>
      </command_interface>
      <state_interface name="velocity"/>
      <state_interface name="position"/>
    </joint>

    <joint name="right_front_wheel_joint">
      <command_interface name="velocity">
        <param name="min">-10</param>
        <param name="max">10</param>
      </command_interface>
      <state_interface name="velocity"/>
      <state_interface name="position"/>
    </joint>

    <!-- Fork lift joint -->
    <joint name="fork_lift_joint">
      <command_interface name="position">
        <param name="min">-0.12</param>
        <param name="max">0.5</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

  <!-- Gazebo ros2_control plugin -->
  <gazebo>
    <plugin filename="libgazebo_ros2_control.so" name="gazebo_ros2_control">
      <parameters>$(find forklift_bot)/config/controllers.yaml</parameters>
    </plugin>
  </gazebo>

  <!-- CAMERA -->
  <gazebo reference="camera_link">
    <sensor type="camera" name="camera">
      <always_on>true</always_on>
      <update_rate>30.0</update_rate>
      <camera>
        <horizontal_fov>1.39</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.05</near>
          <far>50</far>
        </clip>
      </camera>
      <plugin name="camera_controller" filename="libgazebo_ros_camera.so">
        <cameraName>camera</cameraName>
        <imageTopicName>image_raw</imageTopicName>
        <cameraInfoTopicName>camera_info</cameraInfoTopicName>
        <frameName>camera_link</frameName>
      </plugin>
    </sensor>
  </gazebo>

  <!-- Wheel friction and materials -->
  <gazebo reference="left_front_wheel"><mu1>1.5</mu1><mu2>1.5</mu2><kp>1000000.0</kp><kd>100.0</kd><material>Gazebo/FlatBlack</material></gazebo>
  <gazebo reference="right_front_wheel"><mu1>1.5</mu1><mu2>1.5</mu2><kp>1000000.0</kp><kd>100.0</kd><material>Gazebo/FlatBlack</material></gazebo>
  <gazebo reference="left_rear_wheel"><mu1>0.3</mu1><mu2>0.3</mu2><kp>1000000.0</kp><kd>0.1</kd><material>Gazebo/FlatBlack</material></gazebo>
  <gazebo reference="right_rear_wheel"><mu1>0.3</mu1><mu2>0.3</mu2><kp>1000000.0</kp><kd>0.1</kd><material>Gazebo/FlatBlack</material></gazebo>

  <!-- Colors -->
  <gazebo reference="base_link"><material>Gazebo/Orange</material></gazebo>
  <gazebo reference="mast_link"><material>Gazebo/Black</material></gazebo>
  <gazebo reference="fork_carriage"><material>Gazebo/Yellow</material></gazebo>
  <gazebo reference="left_fork"><material>Gazebo/Yellow</material><mu1>2000.0</mu1><mu2>2000.0</mu2></gazebo>
  <gazebo reference="right_fork"><material>Gazebo/Yellow</material><mu1>2000.0</mu1><mu2>2000.0</mu2></gazebo>

</robot>
