    <!-- Warehouse Walls -->
    <!-- Back wall (behind pallets) -->
    <model name="wall_back">
      <static>true</static>
      <pose>8 -3 1.0 0 0 0</pose>
      <link name="link">
        <visual name="visual">
          <geometry><box><size>0.2 16 2.0</size></box></geometry>
          <material><ambient>0.5 0.5 0.5 1</ambient><diffuse>0.6 0.6 0.6 1</diffuse></material>
        </visual>
        <collision name="collision">
          <geometry><box><size>0.2 16 2.0</size></box></geometry>
