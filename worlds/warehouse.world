    <!-- Conveyor Belt (Drop-off location) -->
    <model name="conveyor_belt">
      <static>true</static>
      <pose>-3.5 0 0.01 0 0 0</pose>
      <link name="link">
        <visual name="visual">
          <geometry><box><size>2.0 1.5 0.02</size></box></geometry>
          <material><ambient>0.8 0.1 0.1 1</ambient><diffuse>1 0 0 1</diffuse></material>
        </visual>
